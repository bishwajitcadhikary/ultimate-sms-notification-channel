{
    "name": "frolax/ultimate-sms-notification-channel",
    "description": "Laravel notification channel for UltimateSms",
    "keywords": ["laravel", "notifications", "ultimate-sms", "ultimate", "sms"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Bishwajit Adhikary",
            "email": "bishwajitcadhikary@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/notifications": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.0|^10.4|^11.5"
    },
    "autoload": {
        "psr-4": {
            "Frolax\\UltimateSms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Frolax\\UltimateSms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Frolax\\UltimateSms\\UltimateSmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
